---
import BaseLayout from "@components/base/BaseLayout.astro";
import LiquidGlass from "@components/common/LiquidGlassLess.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"tools">;
}

const { entry } = Astro.props;
const { title, description, tags, icon, file } = entry.data;
const toolUrl = `/tools/${file}`;
---

<BaseLayout title={title} description={description}>
  <div class="container px-3 lg:px-8">
    <!-- 标题栏 -->
    <LiquidGlass heavy containerClass="mb-4" textClass="p-4" animation="fadeDown">
      <div class="flex items-center justify-between flex-wrap gap-3">
        <div class="flex items-center gap-3">
          <a href="/tools" class="text-gray-500 hover:text-orange-500 transition-colors text-sm">← 工具列表</a>
          <span class="text-gray-300 dark:text-gray-600">|</span>
          {icon && <span class="text-xl">{icon}</span>}
          <h1 class="text-xl font-bold text-txt-p dark:text-darkmode-txt-p">{title}</h1>
        </div>
        {tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-1">
            {tags.map((tag) => (
              <span class="px-2 py-0.5 glass-l text-xs rounded-full text-gray-700 dark:text-gray-300">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </div>
      {description && (
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">{description}</p>
      )}
    </LiquidGlass>

    <!-- 工具内容区：iframe 自适应高度 -->
    <LiquidGlass heavy textClass="p-2" animation="fadeUp">
      <iframe
        id="tool-iframe"
        src={toolUrl}
        title={title}
        scrolling="no"
        class="w-full rounded-xl border-0 block"
        style="min-height: 400px;"
        sandbox="allow-scripts allow-forms allow-same-origin allow-popups allow-modals"
      />
    </LiquidGlass>
  </div>
</BaseLayout>

<script>
  // 让 iframe 高度自适应内容，避免出现滚动条
  function resizeIframe() {
    const iframe = document.getElementById("tool-iframe") as HTMLIFrameElement;
    if (!iframe) return;

    function setHeight() {
      try {
        const body = iframe.contentDocument?.body;
        const html = iframe.contentDocument?.documentElement;
        if (!body || !html) return;
        const height = Math.max(
          body.scrollHeight,
          body.offsetHeight,
          html.scrollHeight,
          html.offsetHeight
        );
        iframe.style.height = height + 32 + "px";
      } catch (e) {
        // 跨域时无法访问，保持默认高度
      }
    }

    iframe.addEventListener("load", () => {
      setHeight();
      // 内容可能动态变化，持续监听
      try {
        const resizeObs = new ResizeObserver(setHeight);
        if (iframe.contentDocument?.body) {
          resizeObs.observe(iframe.contentDocument.body);
        }
      } catch (e) {}
    });
  }

  document.addEventListener("DOMContentLoaded", resizeIframe);
  document.addEventListener("astro:page-load", resizeIframe);
</script>

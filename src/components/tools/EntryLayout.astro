---
import BaseLayout from "@components/base/BaseLayout.astro";
import LiquidGlass from "@components/common/LiquidGlassLess.astro";
import type { CollectionEntry } from "astro:content";

interface Props {
  entry: CollectionEntry<"tools">;
}

const { entry } = Astro.props;
const { title, description, tags, icon, file } = entry.data;
const toolUrl = `/tools-embed/${file}`;
---

<BaseLayout title={title} description={description}>
  <div class="container px-3 lg:px-8">
    <!-- 标题栏 -->
    <LiquidGlass heavy containerClass="mb-4" textClass="p-4" animation="fadeDown">
      <div class="flex items-center justify-between flex-wrap gap-3">
        <div class="flex items-center gap-3">
          <a href="/tools" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-lg text-sm font-medium bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-300 hover:bg-orange-50 dark:hover:bg-orange-900/20 hover:text-orange-500 dark:hover:text-orange-400 transition-colors">← 返回工具列表</a>
          <span class="text-gray-300 dark:text-gray-600">|</span>
          {icon && <span class="text-xl">{icon}</span>}
          <h1 class="text-xl font-bold text-txt-p dark:text-darkmode-txt-p">{title}</h1>
        </div>
        {tags && tags.length > 0 && (
          <div class="flex flex-wrap gap-1">
            {tags.map((tag) => (
              <span class="px-2 py-0.5 glass-l text-xs rounded-full text-gray-700 dark:text-gray-300">
                #{tag}
              </span>
            ))}
          </div>
        )}
      </div>
      {description && (
        <p class="text-sm text-gray-500 dark:text-gray-400 mt-2">{description}</p>
      )}
    </LiquidGlass>

    <!-- 工具内容区：iframe 自适应高度 -->
    <LiquidGlass heavy textClass="p-2" animation="fadeUp">
      <iframe
        id="tool-iframe"
        src={toolUrl}
        title={title}
        class="w-full rounded-xl border-0 block"
        style="min-height: 500px; height: 500px;"
        sandbox="allow-scripts allow-forms allow-same-origin allow-popups allow-modals allow-downloads"
      />
    </LiquidGlass>
  </div>
</BaseLayout>

<script>
  function initIframe() {
    const iframe = document.getElementById("tool-iframe") as HTMLIFrameElement;
    if (!iframe) return;

    // 监听工具页面通过 postMessage 发来的高度
    window.addEventListener("message", (e) => {
      if (e.data && e.data.type === "tool-height") {
        iframe.style.height = e.data.height + "px";
      }
    });

    // 备用：load 后尝试直接读取高度
    iframe.addEventListener("load", () => {
      try {
        const h = iframe.contentDocument?.documentElement?.scrollHeight;
        if (h && h > 100) iframe.style.height = h + 32 + "px";
      } catch (_) {}
    });
  }

  document.addEventListener("DOMContentLoaded", initIframe);
  document.addEventListener("astro:page-load", initIframe);
</script>

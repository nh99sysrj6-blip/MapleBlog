---
import type { CollectionEntry } from "astro:content";
import LiquidGlass from "@components/common/LiquidGlassLess.astro";
import { slugify } from "@lib/textConverter";

interface Props {
  entry: CollectionEntry<"tools">;
}

const { entry } = Astro.props;
const { title, description, icon, tags } = entry.data;
const slug = slugify(title);
---

<LiquidGlass
  heavy
  wrapperClass="dock rounded-xl hover:scale-[1.02] transition-transform duration-300"
  textClass="h-full"
  animation="fadeUp"
>
  <a href={`/tools/${slug}`} class="block p-5 h-full">
    <div class="flex items-center gap-3 mb-3">
      {icon && <span class="text-2xl">{icon}</span>}
      <h3 class="text-lg font-bold text-txt-p dark:text-darkmode-txt-p">{title}</h3>
    </div>
    {description && (
      <p class="text-sm text-gray-600 dark:text-gray-400 mb-3 line-clamp-2">{description}</p>
    )}
    {tags && tags.length > 0 && (
      <div class="flex flex-wrap gap-1">
        {tags.map((tag) => (
          <span class="px-2 py-0.5 glass-l text-xs rounded-full text-gray-700 dark:text-gray-300">
            #{tag}
          </span>
        ))}
      </div>
    )}
  </a>
</LiquidGlass>
